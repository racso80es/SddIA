{
  "spec_version": "2.0.0",
  "process_id": "create-tool",
  "name": "Create Tool",
  "description": "Proceso para la creación de una nueva herramienta (tool) en paths.toolsPath: cápsula, índice, Cúmulo; Arsenal Táctico Git S+.",
  "process_doc_ref": "paths.processPath/create-tool/",
  "contract_ref": "paths.processPath/process-contract.json",
  "tools_contract_ref": "SddIA/tools/tools-contract.json",
  "persist_ref": "paths.featurePath/create-tool-<tool-id>",
  "paths": {
    "toolsPath_ref": "paths.toolsPath (Cúmulo)",
    "toolsDefinitionPath": "./SddIA/tools/",
    "toolsIndexPath_ref": "paths.toolsIndexPath (Cúmulo)",
    "featurePath_ref": "paths.featurePath (Cúmulo)",
    "toolCapsulesRef": "paths.toolCapsules"
  },
  "process_interface_compliance": "Genera en carpeta de la tarea un .md por acción con YAML Frontmatter; entrega ejecutable: cápsula en paths.toolCapsules[<tool-id>]. Norma: features-documentation-frontmatter.md.",
  "triggers": ["Crear nueva herramienta en paths.toolsPath", "Solicitud de creación de herramienta con tool-id"],
  "inputs": { "tool_id": "kebab-case. Obligatorio.", "description": "Descripción breve. Obligatorio." },
  "related_actions": ["spec", "implementation", "validate", "finalize-process"],
  "related_skills": [
    "git-workspace-recon",
    "git-branch-manager",
    "git-save-snapshot",
    "git-sync-remote",
    "git-tactical-retreat",
    "git-create-pr"
  ],
  "phases": [
    { "id": "0", "name": "Preparar entorno", "description": "git-workspace-recon; git-branch-manager (feat/create-tool-<tool-id>)." },
    { "id": "1", "name": "Especificación y definición SddIA", "description": "objectives.md, spec.md; paths.toolsDefinitionPath." },
    { "id": "2", "name": "Implementación de cápsula e integración", "description": "Cápsula, índice, Cúmulo; git-save-snapshot; git-tactical-retreat si emergencia." },
    { "id": "3", "name": "Validar", "description": "Validación contractual y funcional." },
    { "id": "4", "name": "Finalizar", "description": "git-sync-remote; git-create-pr (objectives + validacion en PR)." }
  ]
}
